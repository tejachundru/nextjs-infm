# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# TypeScript build artifacts (excluding config files)
**/*.js.map
!**/*.config.js
!jest.config.js
!next.config.js
server/prisma/*.js
server/prisma/*.d.ts

# docs
/docs/medium

# Docker volumes
postgres_data/
pgadmin_data/

# Server NestJS
server/node_modules/
server/dist/
server/.env
server/.env.local
